{
  "name": "outlierfit-playwright-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:browsers": "playwright install",
    "test": "npm run test:api",
    "test:api": "cucumber-js --profile api",
    "test:cucumber": "cucumber-js",
    "test:ui": "cucumber-js --profile ui \"tests/ui/features/**/*.feature\"",
    "test:ui:headed": "cucumber-js --profile ui \"tests/ui/features/**/*.feature\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.9.0"
  }
}
